# Database (dev local: puerto 5433 porque 5432 puede estar ocupado)
DATABASE_URL=postgresql+asyncpg://mpv2:mpv2@localhost:5433/mpv2

# Redis (dev local: puerto 6380 porque 6379 puede estar ocupado)
REDIS_URL=redis://localhost:6380/0

# FAL.AI
FAL_KEY=your_fal_api_key_here

# Ollama (dentro de Docker usar host.docker.internal, fuera usar localhost)
OLLAMA_BASE_URL=http://localhost:11434

# Paths
MP_DIR=.mp
CONFIG_PATH=config.json

# Tavily (web search para tech videos)
TAVILY_API_KEY=your_tavily_api_key_here

# Remotion microservice
# Local dev:
REMOTION_SERVICE_URL=http://localhost:3001
# Docker Compose (override in .env when running with docker-compose):
# REMOTION_SERVICE_URL=http://remotion-service:3001
